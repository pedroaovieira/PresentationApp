<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_container_low"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface_container_low"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Dark" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="40dp">

            <!-- App icon -->
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="App icon" />

            <!-- Brand name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TEMPORAL"
                android:textColor="@color/primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="@font/space_grotesk"
                android:letterSpacing="0.15"
                android:layout_marginTop="20dp" />

            <!-- Version -->
            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Version 1.2.0"
                android:textColor="@color/outline"
                android:textSize="13sp"
                android:fontFamily="@font/manrope"
                android:layout_marginTop="6dp" />

            <!-- Tagline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full-screen countdown for presenters"
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:layout_marginTop="10dp" />

            <!-- Divider -->
            <View
                android:layout_width="48dp"
                android:layout_height="2dp"
                android:background="@color/outline_variant"
                android:layout_marginTop="32dp" />

            <!-- "DEVELOPED BY" label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEVELOPED BY"
                android:textColor="@color/outline"
                android:textSize="10sp"
                android:fontFamily="@font/manrope"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:layout_marginTop="28dp" />

            <!-- Pedro Vieira card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/surface_container_high"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="PV"
                        android:textColor="@color/on_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/space_grotesk"
                        android:gravity="center"
                        android:background="@drawable/circle_primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pedro Vieira"
                            android:textColor="@color/on_surface"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="App Developer"
                            android:textColor="@color/outline"
                            android:textSize="12sp"
                            android:fontFamily="@font/manrope" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Claude.ai card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/surface_container_high"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="AI"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/space_grotesk"
                        android:gravity="center"
                        android:background="@drawable/circle_claude" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Claude.ai"
                            android:textColor="@color/on_surface"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI Development Partner · Anthropic"
                            android:textColor="@color/outline"
                            android:textSize="12sp"
                            android:fontFamily="@font/manrope" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Website link -->
            <TextView
                android:id="@+id/tvWebsite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="pedrov.org"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:fontFamily="@font/manrope"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                android:padding="6dp"
                android:background="?attr/selectableItemBackground" />

            <!-- License / copyright -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open Source · MIT License"
                android:textColor="@color/outline"
                android:textSize="12sp"
                android:fontFamily="@font/manrope"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="© 2025 Pedro Vieira"
                android:textColor="@color/outline"
                android:textSize="12sp"
                android:fontFamily="@font/manrope"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
