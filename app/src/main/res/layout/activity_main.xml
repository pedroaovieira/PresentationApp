<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <!-- Progress Aura — 4dp bar at top, colour = active phase -->
    <View
        android:id="@+id/auraBar"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="@color/primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Brand name -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TEMPORAL"
        android:textColor="@color/primary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:fontFamily="@font/space_grotesk"
        android:letterSpacing="0.2"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/auraBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Settings gear (setup screen only) -->
    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_settings"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Settings"
        android:padding="10dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/auraBar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- SETUP PANEL: visible only in TimerPhase.SETUP -->
    <LinearLayout
        android:id="@+id/setupPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintBottom_toTopOf="@id/buttonRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SET THE\nPACE"
            android:textColor="@color/on_surface"
            android:textSize="52sp"
            android:textStyle="bold"
            android:fontFamily="@font/space_grotesk"
            android:letterSpacing="-0.02"
            android:lineSpacingMultiplier="0.88"
            android:gravity="center"
            android:layout_marginBottom="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SESSION DURATION"
            android:textColor="@color/outline"
            android:textSize="10sp"
            android:fontFamily="@font/manrope"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginBottom="20dp" />

        <!-- HH : MM : SS inputs on dark card -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/surface_container_low"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp">

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="HH" android:textSize="9sp" android:fontFamily="@font/manrope"
                    android:letterSpacing="0.1" android:textColor="@color/outline" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/inputHours" android:layout_width="72dp" android:layout_height="wrap_content"
                    android:inputType="number" android:maxLength="2" android:gravity="center"
                    android:textSize="44sp" android:textStyle="bold" android:fontFamily="@font/space_grotesk"
                    android:textColor="@color/on_surface" android:textColorHint="@color/outline_variant"
                    android:background="@null" android:hint="00" android:padding="0dp"/>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text=":" android:textSize="36sp" android:fontFamily="@font/space_grotesk"
                android:textColor="@color/outline_variant" android:paddingBottom="4dp" android:paddingHorizontal="6dp"/>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="MM" android:textSize="9sp" android:fontFamily="@font/manrope"
                    android:letterSpacing="0.1" android:textColor="@color/outline" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/inputMinutes" android:layout_width="72dp" android:layout_height="wrap_content"
                    android:inputType="number" android:maxLength="2" android:gravity="center"
                    android:textSize="44sp" android:textStyle="bold" android:fontFamily="@font/space_grotesk"
                    android:textColor="@color/on_surface" android:textColorHint="@color/outline_variant"
                    android:background="@null" android:hint="00" android:padding="0dp"/>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text=":" android:textSize="36sp" android:fontFamily="@font/space_grotesk"
                android:textColor="@color/outline_variant" android:paddingBottom="4dp" android:paddingHorizontal="6dp"/>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SS" android:textSize="9sp" android:fontFamily="@font/manrope"
                    android:letterSpacing="0.1" android:textColor="@color/outline" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/inputSeconds" android:layout_width="72dp" android:layout_height="wrap_content"
                    android:inputType="number" android:maxLength="2" android:gravity="center"
                    android:textSize="44sp" android:textStyle="bold" android:fontFamily="@font/space_grotesk"
                    android:textColor="@color/on_surface" android:textColorHint="@color/outline_variant"
                    android:background="@null" android:hint="00" android:padding="0dp"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- TIMER AREA: visible in RUNNING / PAUSED / FINISHED -->

    <TextView
        android:id="@+id/tvPhaseLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ON TRACK"
        android:textColor="@color/on_surface"
        android:textSize="20sp"
        android:fontFamily="@font/manrope"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:visibility="gone"
        android:layout_marginTop="56dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="ON TRACK" />

    <!-- The Monolith: massive countdown -->
    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="25:00"
        android:textColor="@color/on_surface"
        android:textSize="88sp"
        android:textStyle="bold"
        android:fontFamily="@font/space_grotesk"
        android:letterSpacing="-0.04"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvPhaseLabel"
        app:layout_constraintBottom_toTopOf="@id/progressRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="18:42" />

    <!-- Thin linear progress bar + REMAINING label -->
    <LinearLayout
        android:id="@+id/progressRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginHorizontal="64dp"
        android:layout_marginBottom="32dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/buttonRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressArc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progress="100"
            app:indicatorColor="@color/primary"
            app:trackColor="@color/surface_container_low"
            app:trackThickness="4dp"
            app:trackCornerRadius="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REMAINING"
            android:textColor="@color/outline"
            android:textSize="9sp"
            android:fontFamily="@font/manrope"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- BUTTON ROW: always anchored to the bottom -->
    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="52dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Reset / Stop: dark circle -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReset"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_stop"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="24dp"
            android:text=""
            app:backgroundTint="@color/surface_container_highest"
            app:cornerRadius="32dp"
            android:visibility="gone"
            android:layout_marginEnd="20dp" />

        <!-- Pause: primary circle, large -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPause"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_pause"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="32dp"
            android:text=""
            app:backgroundTint="@color/primary"
            app:cornerRadius="44dp"
            android:visibility="gone" />

        <!-- Start / Resume / Initialize: pill, primary -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStart"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="INITIALIZE"
            android:textColor="@color/on_primary"
            android:textSize="13sp"
            android:fontFamily="@font/manrope"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:paddingHorizontal="40dp"
            app:backgroundTint="@color/primary"
            app:cornerRadius="28dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
