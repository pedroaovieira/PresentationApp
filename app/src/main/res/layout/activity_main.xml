<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_green"
    tools:context=".MainActivity">

    <!-- Phase label -->
    <TextView
        android:id="@+id/tvPhaseLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Set your time"
        android:textSize="18sp"
        android:textColor="@color/text_on_color"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.05"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <!-- Circular progress + timer container -->
    <FrameLayout
        android:id="@+id/timerContainer"
        android:layout_width="280dp"
        android:layout_height="280dp"
        app:layout_constraintTop_toBottomOf="@id/tvPhaseLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <!-- Arc progress -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressArc"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            app:indicatorSize="280dp"
            app:trackThickness="14dp"
            app:trackColor="#33000000"
            app:indicatorColor="@color/arc_green"
            android:progress="100"
            app:trackCornerRadius="7dp" />

        <!-- Timer text -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="00:00"
            android:textSize="64sp"
            android:textColor="@color/text_on_color"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="-0.03"
            tools:text="25:00" />

    </FrameLayout>

    <!-- Setup panel: H / M / S inputs -->
    <LinearLayout
        android:id="@+id/setupPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/timerContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:hint="HH"
            app:boxStrokeColor="@color/text_on_color"
            app:hintTextColor="@color/text_on_color"
            app:boxStrokeWidth="1.5dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputHours"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@color/text_on_color"
                android:gravity="center"
                android:textSize="22sp"
                android:maxLength="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textSize="28sp"
            android:textColor="@color/text_on_color"
            android:layout_marginHorizontal="4dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:hint="MM"
            app:boxStrokeColor="@color/text_on_color"
            app:hintTextColor="@color/text_on_color"
            app:boxStrokeWidth="1.5dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputMinutes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@color/text_on_color"
                android:gravity="center"
                android:textSize="22sp"
                android:maxLength="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textSize="28sp"
            android:textColor="@color/text_on_color"
            android:layout_marginHorizontal="4dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:hint="SS"
            app:boxStrokeColor="@color/text_on_color"
            app:hintTextColor="@color/text_on_color"
            app:boxStrokeWidth="1.5dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputSeconds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@color/text_on_color"
                android:gravity="center"
                android:textSize="22sp"
                android:maxLength="2" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- Button row -->
    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="56dp">

        <!-- Start / Resume -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStart"
            android:layout_width="140dp"
            android:layout_height="56dp"
            android:text="Start"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            app:backgroundTint="#CC000000"
            app:cornerRadius="28dp"
            android:layout_marginEnd="12dp" />

        <!-- Pause -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPause"
            android:layout_width="140dp"
            android:layout_height="56dp"
            android:text="Pause"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            app:backgroundTint="#CC000000"
            app:cornerRadius="28dp"
            android:visibility="gone"
            android:layout_marginEnd="12dp" />

        <!-- Reset -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReset"
            android:layout_width="140dp"
            android:layout_height="56dp"
            android:text="Reset"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            app:backgroundTint="#66000000"
            app:cornerRadius="28dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
